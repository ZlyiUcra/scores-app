# Copy to .env and adjust. In production JWT_SECRET is REQUIRED (server refuses
# to start without it); in development a random secret is generated per boot.
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
# Client origin allowed for CORS in production (dev uses the Vite proxy).
CLIENT_ORIGIN=http://localhost:5173
# Reverse-proxy hops to trust for X-Forwarded-For (Express "trust proxy").
# Leave unset for local dev and any direct-access deployment - the Vite dev
# proxy does not inject X-Forwarded-For, so there is no hop to trust here,
# and trusting one when there is none lets a client fake its own rate-limit
# bucket. Set to 1 only when deployed behind exactly one TLS-terminating
# reverse proxy that sets the header (Render and similar PaaS).
# TRUST_PROXY=1
